# Required in production. Use at least 32 random characters.
AUTH_SECRET="replace-with-a-strong-random-secret"

# Optional until a managed Postgres adapter is wired in. Migration SQL is in db/migrations.
DATABASE_URL="postgresql://user:password@localhost:5432/procureiq"

# Local development JSON persistence path used by the current server adapter.
PROCUREIQ_DATA_PATH="/tmp/procureiq-data.json"

# Safe quote-document upload defaults for future file ingestion routes.
MAX_UPLOAD_BYTES="10000000"
ALLOWED_UPLOAD_MIME_TYPES="application/pdf,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
