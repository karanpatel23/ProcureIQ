# Required in production. Generate your own value, e.g. `openssl rand -base64 32`. Never commit a real secret.
AUTH_SECRET="replace-with-at-least-32-random-characters--generated-per-environment"

# When set, workspace state persists in Postgres (recommended for any hosted deployment,
# e.g. Neon or Vercel Postgres). Leave unset to use the local JSON file adapter.
DATABASE_URL="postgresql://user:password@localhost:5432/corven"

# Local development JSON persistence path used by the current server adapter.
CORVEN_DATA_PATH="/tmp/corven-data.json"
QUOTE_STORAGE_PATH="/tmp/corven-quotes"

# Safe quote-document upload defaults for future file ingestion routes.
MAX_UPLOAD_BYTES="10000000"
ALLOWED_UPLOAD_MIME_TYPES="application/pdf,image/png,image/jpeg,text/plain,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"

# Billing is disabled by default. Set BILLING_PROVIDER=stripe and provide keys when checkout is implemented.
BILLING_PROVIDER="none"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Comma-separated emails allowed to view /admin and internal admin APIs.
INTERNAL_ADMIN_EMAILS="founders@corven.com"

# Email delivery (RFQ/PO sending + account verification). When both are set,
# email verification is REQUIRED before login; without them, accounts are
# auto-verified so demos are never locked out. Use a verified Resend sender.
RESEND_API_KEY=""
EMAIL_FROM="Corven <noreply@yourdomain.com>"
# Public base URL used in verification, reset, and OAuth callback links; defaults
# to the request origin. Set this in production so links point at your real domain.
APP_URL=""

# OAuth sign-in (Google / Microsoft). Each provider's button goes live the moment
# its client id + secret are set; until then the UI shows it as "coming soon".
# Register the callback URL ${APP_URL}/api/auth/oauth/google/callback (and
# .../microsoft/callback) in each provider's console.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_CLIENT_SECRET=""
# 'common' allows any work/school or personal Microsoft account; set a tenant id to restrict.
MICROSOFT_OAUTH_TENANT="common"

# Google Search Console verification. Paste the token from the "HTML tag" method
# (the content value only) to verify domain ownership and submit the sitemap.
GOOGLE_SITE_VERIFICATION=""

# AI extraction defaults to the local deterministic parser until a provider is configured.
AI_PROVIDER="local"
OPENAI_API_KEY=""

# Claude-powered extraction/intake/drafting. Set AI_PROVIDER=anthropic and an
# API key to upgrade parsing from the deterministic local extractor to Claude
# (the local parser remains the automatic fallback on any failure).
# AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# Supplier-facing email sandbox (RFQ/PO sends). Default ON: outbound supplier
# mail is redirected to SANDBOX_EMAIL_TO (or suppressed if unset) so no real
# supplier is ever emailed accidentally. Set SANDBOX_MODE=off to go live.
SANDBOX_MODE="on"
SANDBOX_EMAIL_TO=""
